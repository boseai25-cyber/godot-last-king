[gd_project]

config_version=5

[application]

config/name="The Last King"
config/description="A 3D strategy-action chess game with psychological horror elements"
config/version="1.0.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.1", "3d")
config/icon="res://assets/icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=1

[physics]

3d/default_gravity=0.0

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
environment/ambient_light/ambient_light_source=1
environment/ambient_light/ambient_light_energy=0.3

[debug]

gdscript/warnings/unused_variable=1
gdscript/warnings/unused_signal=1
